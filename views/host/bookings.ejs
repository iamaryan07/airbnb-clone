<%- include('../partials/head') %>

<body class="bg-gray-50 text-gray-900">

  <%- include('../partials/nav') %>

  <!-- Page Header -->
  <section class="max-w-7xl mx-auto px-6 pt-16 pb-8 text-center">

    <span class="inline-block text-xs font-medium tracking-widest uppercase text-rose-600 bg-rose-50 px-4 py-1 rounded-full mb-5">
      Host Dashboard
    </span>

    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4">
      Incoming Bookings
    </h1>

    <p class="text-gray-500 text-base max-w-xl mx-auto">
      Review and manage all guest reservations across your listed properties.
    </p>

  </section>

  <!-- Bookings List -->
  <section class="max-w-7xl mx-auto px-6 pb-16">

    <!-- Header row -->
    <div class="flex justify-between items-center mb-10">
      <h2 class="text-2xl font-semibold">All Reservations</h2>
      <% if (bookings && bookings.length > 0) { %>
        <span class="text-sm text-gray-400"><%= bookings.length %> <%= bookings.length === 1 ? 'reservation' : 'reservations' %></span>
      <% } %>
    </div>

    <% if (bookings && bookings.length > 0) { %>

      <div class="flex flex-col gap-6">

        <% bookings.forEach(booking => { %>

          <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-lg hover:-translate-y-1 transition duration-300 flex flex-col md:flex-row">

            <!-- Image -->
            <div class="md:w-72 shrink-0 relative">
              <img
               src="<%= booking.home?.url?.[0] 
                  ? (booking.home.url[0].startsWith('http') 
                      ? booking.home.url[0] 
                      : '/uploads/' + booking.home.url[0]) 
                  : 'https://via.placeholder.com/400' %>"
                class="w-full h-56 md:h-full object-cover"
              />
              <span class="absolute top-3 left-3 text-xs font-medium bg-white/90 px-3 py-1 rounded-full">
                Entire home
              </span>
            </div>

            <!-- Details -->
            <div class="flex-1 p-6 flex flex-col justify-between gap-4">

              <!-- Top -->
              <div class="flex flex-col gap-2">

                <!-- Property Title + Rating -->
                <div class="flex justify-between items-start">
                  <h2 class="text-lg font-semibold leading-snug">
                    <%= booking.home?.houseName || "Unknown Property" %>
                  </h2>
                  <span class="text-sm font-medium text-amber-600 whitespace-nowrap">
                    ★ <%= booking.home?.rating || "4.5" %>
                  </span>
                </div>

                <!-- Location -->
                <p class="text-sm text-gray-500 flex items-center gap-1">
                  <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <%= booking.home?.location || "Unknown location" %>
                </p>

                <!-- Guest Info -->
                <div class="mt-1 flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                  </svg>
                  <span class="text-sm text-gray-600">
                    Guest: <span class="font-medium text-gray-800"><%= booking.user?.name || booking.user?.email || "Unknown guest" %></span>
                  </span>
                </div>

                <!-- Dates -->
                <div class="mt-2 flex flex-wrap gap-3">

                  <div class="flex items-center gap-2 bg-gray-50 border border-gray-100 rounded-xl px-4 py-2.5">
                    <svg class="w-4 h-4 text-rose-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                      <line x1="16" y1="2" x2="16" y2="6"/>
                      <line x1="8" y1="2" x2="8" y2="6"/>
                      <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    <div>
                      <p class="text-xs text-gray-400 leading-none mb-0.5">Check-in</p>
                      <p class="text-sm font-medium"><%= booking.fromDate %></p>
                    </div>
                  </div>

                  <div class="flex items-center gap-2 bg-gray-50 border border-gray-100 rounded-xl px-4 py-2.5">
                    <svg class="w-4 h-4 text-rose-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                      <line x1="16" y1="2" x2="16" y2="6"/>
                      <line x1="8" y1="2" x2="8" y2="6"/>
                      <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    <div>
                      <p class="text-xs text-gray-400 leading-none mb-0.5">Check-out</p>
                      <p class="text-sm font-medium"><%= booking.toDate %></p>
                    </div>
                  </div>

                </div>

              </div>

              <!-- Bottom -->
              <div class="pt-4 border-t border-gray-100 flex items-center justify-between">
                <div>
                  <span class="text-lg font-semibold">$<%= booking.totalPrice %></span>
                  <span class="text-sm text-gray-400"> earned</span>
                </div>

                <div class="flex items-center gap-3">
                  <a href="/homes/<%= booking.home?._id %>"
                    class="text-sm font-medium text-gray-600 border border-gray-200 px-5 py-2.5 rounded-xl hover:bg-gray-50 transition">
                    View Listing
                  </a>
                  <form action="/bookings/<%= booking._id %>/cancel" method="POST" onsubmit="return confirm('Are you sure you want to cancel this reservation?')">
                    <button type="submit"
                      class="text-sm font-medium text-rose-500 border border-rose-200 px-5 py-2.5 rounded-xl hover:bg-rose-50 transition">
                      Cancel
                    </button>
                  </form>
                </div>
              </div>

            </div>

          </div>

        <% }) %>

      </div>

    <% } else { %>

      <!-- Empty state -->
      <div class="text-center py-24">
        <p class="text-gray-400 mb-4">No reservations yet. Once guests book your properties, they'll appear here.</p>
        <a href="/homes/new"
          class="inline-block text-sm font-medium text-white bg-rose-500 px-6 py-3 rounded-xl hover:bg-rose-600 transition">
          List a Property
        </a>
      </div>

    <% } %>

  </section>

</body>
</html>
