<%- include('../partials/head') %>

<body>

  <%- include('../partials/nav') %>

  <section class="detail-section">

    <!-- Title -->
    <div class="detail-header">
      <div>
        <span class="pill-badge">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <circle cx="5" cy="5" r="4" fill="var(--color-rose)" opacity="0.25"/>
            <circle cx="5" cy="5" r="2" fill="var(--color-rose)"/>
          </svg>
          Entire home
        </span>
        <h1 class="detail-title"><%= home.houseName %></h1>
        <div class="detail-meta">
          <span class="detail-rating">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <%= home.rating || "4.5" %>
          </span>
          <span class="meta-dot" aria-hidden="true">·</span>
          <span class="detail-location-text">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <%= home.location || "Unknown location" %>
          </span>
        </div>
      </div>
    </div>

    <!-- Main Layout -->
    <div class="detail-grid">

      <!-- Image Slider -->
      <div class="detail-img-wrap" data-images='<%- JSON.stringify(home.url) %>'>
        <img class="slider detail-img" src="<%= home.url[0] %>" alt="<%= home.houseName %>"/>

        <button onclick="prevImage(this)" class="slider-btn slider-btn-prev" aria-label="Previous image">
          <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button onclick="nextImage(this)" class="slider-btn slider-btn-next" aria-label="Next image">
          <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        <span class="img-badge">Entire home</span>
        <div class="slider-dots"></div>
      </div>

      <!-- Details & Booking -->
      <div class="detail-sidebar">

        <!-- Description -->
        <div class="detail-about">
          <h2 class="sidebar-heading">About this place</h2>
          <p class="detail-desc">
            <%= home.description || "Cozy and comfortable stay with great amenities nearby. Perfect for travelers looking for convenience and comfort." %>
          </p>
        </div>

        <!-- Price -->
        <div class="detail-price-row">
          <span class="detail-price">$<%= home.price || "120" %></span>
          <span class="detail-price-unit">/ night</span>
        </div>

        <!-- House Rules -->
        <% if (home.rules) { %>
          <a href="/rules/<%= home.rules %>" target="_blank" class="rules-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
            </svg>
            View House Rules
          </a>
        <% } %>

        <!-- Favourite -->
        <div class="detail-favourite">
          <%- include('../partials/favourites') %>
        </div>

        <!-- Booking Form -->
        <div class="booking-box">
          <h3 class="sidebar-heading">Book your stay</h3>

          <% if (activeBooking) { %>
            <p class="booked-text">
              Booked from 
              <%= new Date(activeBooking.fromDate).toLocaleDateString() %>
              to 
              <%= new Date(activeBooking.toDate).toLocaleDateString() %>
            </p>
          <% } else { %>

            <form action="/host/bookings" method="POST" class="booking-form">
              <input type="hidden" name="homeId" value="<%= home._id %>">

              <div class="date-row">
                <div class="date-field">
                  <label>Check-in</label>
                  <input type="date" name="fromDate" required />
                </div>

                <div class="date-field">
                  <label>Check-out</label>
                  <input type="date" name="toDate" required />
                </div>
              </div>

              <button type="submit" class="btn-book">Book now</button>
            </form>

          <% } %>
        </div>

    </div>

  </section>

  <%- include('../partials/image-slider') %>

</body>

<style>
  .detail-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.5rem 6rem;
  }

  /* Header */
  .detail-header {
    margin-bottom: 2rem;
  }

  .pill-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-rose);
    background: var(--color-rose-soft);
    border: 1px solid #fecdd3;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-pill);
    margin-bottom: 1rem;
  }

  .detail-title {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    line-height: 1.15;
  }

  .detail-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .detail-rating {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #d97706;
  }

  .detail-rating svg { flex-shrink: 0; }

  .meta-dot { color: var(--color-border); font-size: 1.125rem; }

  .detail-location-text {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.875rem;
    color: var(--color-slate);
  }

  .detail-location-text svg { width: 14px; height: 14px; flex-shrink: 0; }

  /* Grid */
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 3rem;
    align-items: start;
  }

  /* Image */
  .detail-img-wrap {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .detail-img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    display: block;
  }

  .img-badge {
    position: absolute;
    top: 14px; left: 14px;
    font-size: 0.72rem;
    font-weight: 600;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(6px);
    color: var(--color-ink);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
  }

  /* Slider buttons */
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(4px);
    border: none;
    border-radius: 50%;
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.15s ease;
    z-index: 2;
  }

  .slider-btn:hover { background: white; }
  .slider-btn svg { width: 16px; height: 16px; stroke: var(--color-ink); stroke-width: 2.5; fill: none; }
  .slider-btn-prev { left: 12px; }
  .slider-btn-next { right: 12px; }

  /* Sidebar */
  .detail-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 0.625rem;
    letter-spacing: -0.01em;
  }

  .detail-about {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 1.25rem;
    box-shadow: var(--shadow-card);
  }

  .detail-desc {
    font-size: 0.9rem;
    color: var(--color-slate);
    line-height: 1.7;
  }

  /* Price */
  .detail-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    padding: 1.125rem 1.25rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
  }

  .detail-price {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }

  .detail-price-unit {
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  /* Rules */
  .rules-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-rose);
    transition: color 0.15s ease;
  }

  .rules-link:hover { color: var(--color-rose-deep); text-decoration: underline; }

  /* Favourite */
  .detail-favourite {}

  /* Booking Box */
  .booking-box {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
  }

  .booking-form {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .date-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .date-field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .field-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-slate);
  }

  .field-input {
    width: 100%;
    padding: 0.6rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    font-size: 0.875rem;
    color: var(--color-ink);
    background: var(--color-surface, #fafaf9);
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .field-input:focus {
    border-color: var(--color-rose);
    box-shadow: 0 0 0 3px rgba(244,63,94,0.12);
  }

  .price-preview {
    font-size: 0.8125rem;
    color: var(--color-slate);
    min-height: 1.25rem;
  }

  .btn-book {
    width: 100%;
    font-size: 0.9375rem;
    font-weight: 600;
    color: white;
    background: var(--color-rose);
    padding: 0.8rem;
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.1s ease;
  }

  .btn-book:hover {
    background: var(--color-rose-deep);
    box-shadow: 0 6px 20px rgba(244,63,94,0.3);
    transform: translateY(-1px);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .detail-img { height: 340px; }
  }
</style>

</html>
