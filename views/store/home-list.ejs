<!-- Host List Store -->

<%- include('../partials/head') %>

<body class="bg-gray-50 text-gray-900">

  <%- include('../partials/nav') %>

  <!-- Page Header -->
  <section class="max-w-7xl mx-auto px-6 pt-16 pb-8 text-center">
    
    <span class="inline-block text-xs font-medium tracking-widest uppercase text-rose-600 bg-rose-50 px-4 py-1 rounded-full mb-5">
      Browse stays
    </span>

    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4">
      Explore all homes
    </h1>

    <p class="text-gray-500 text-base max-w-xl mx-auto">
      Find the perfect place from our complete collection.
    </p>

  </section>

  <!-- Listings -->
  <section class="max-w-7xl mx-auto px-6 pb-16">

    <!-- Header -->
    <div class="flex justify-between items-center mb-10">
      <h2 class="text-2xl font-semibold">
        All Homes
      </h2>
      <span class="text-sm text-gray-400">
        <%= registeredHomes.length %> results
      </span>
    </div>

    <% if (registeredHomes.length > 0) { %>

      <!-- Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">

        <% registeredHomes.forEach(home => { %>

          <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition duration-300 flex flex-col">

            <!-- Image -->
            <div class="relative w-full aspect-[3/2] overflow-hidden rounded-t-2xl" data-images='<%- JSON.stringify(home.url) %>'>

              <img
                class="slider w-full h-full object-cover"
                src="<%= home.url[0] %>"
              />

              <button
                onclick="prevImage(this)"
                class="absolute z-10 left-3 top-1/2 -translate-y-1/2 bg-white/80 px-3 py-1 rounded-full"
              >
                ◀
              </button>

              <button
                onclick="nextImage(this)"
                class="absolute z-10 right-3 top-1/2 -translate-y-1/2 bg-white/80 px-3 py-1 rounded-full"
              >
                ▶
              </button>

              <span class="absolute top-3 left-3 text-xs font-medium bg-white/90 px-3 py-1 rounded-full">
                Entire home
              </span>

            </div>

            <!-- Content -->
            <div class="p-5 flex flex-col flex-1 gap-3">

              <!-- Title + Rating -->
              <div class="flex justify-between items-start">
                <h3 class="text-base font-semibold leading-snug">
                  <%= home.houseName %>
                </h3>
                <span class="text-sm font-medium text-amber-600 whitespace-nowrap">
                  ★ <%= home.rating || "4.5" %>
                </span>
              </div>

              <!-- Location -->
              <p class="text-sm text-gray-500 flex items-center gap-1">
                <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <%= home.location || "Unknown location" %>
              </p>

              <!-- Description -->
              <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">
                Cozy and comfortable stay with great amenities nearby.
              </p>

              <!-- Price -->
              <div class="mt-auto pt-3 border-t border-gray-100 flex items-center justify-between">
                <div>
                  <span class="text-lg font-semibold">
                    $<%= home.price || "120" %>
                  </span>
                  <span class="text-sm text-gray-400"> / night</span>
                </div>
              </div>

              <!-- CTA -->
              <a href="/homes/<%= home._id %>"
                class="block text-center w-full mt-2 text-sm font-medium text-white bg-rose-500 rounded-xl py-2.5 hover:bg-rose-600 transition">
                View
              </a>

            </div>

          </div>

        <% }) %>

      </div>

    <% } else { %>

      <!-- Empty State -->
      <div class="text-center py-24">
        <p class="text-gray-400 mb-4">
          No homes available.
        </p>
      </div>

    <% } %>

  </section>

<%- include('../partials/image-slider') %>

</body>
</html>