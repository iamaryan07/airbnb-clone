<!-- index.ejs -->

<%- include('../partials/head') %>

<body>

  <%- include('../partials/nav') %>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="hero-section">
    <div class="hero-bg-mesh"></div>
    <div class="hero-inner">

      <span class="pill-badge">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <circle cx="5" cy="5" r="4" fill="var(--color-rose)" opacity="0.25"/>
          <circle cx="5" cy="5" r="2" fill="var(--color-rose)"/>
        </svg>
        Handpicked stays
      </span>

      <h1 class="hero-title">Find your<br><em>next stay</em></h1>

      <p class="hero-sub">
        Discover unique places to stay around the world — curated for comfort, character, and convenience.
      </p>

      <div class="hero-cta-row">
        <!-- CTAs kept commented as in original -->
        <!-- <a href="/homes" class="btn-primary">Browse all homes</a> -->
        <!-- <a href="/favourites" class="btn-ghost">View favourites</a> -->
      </div>

    </div>

    <!-- Decorative wave divider -->
    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="var(--color-surface)"/>
      </svg>
    </div>
  </section>

  <!-- ── Listings ───────────────────────────────────────────────── -->
  <section class="listings-section">

    <div class="listings-header">
      <div>
        <h2 class="section-title">Featured Homes</h2>
        <p class="section-sub">Top-rated stays selected for you</p>
      </div>
      <span class="results-badge"><%= registeredHomes.length %> results</span>
    </div>

    <% if (registeredHomes.length > 0) { %>

      <div class="homes-grid">
        <% registeredHomes.forEach(home => { %>
          <div class="home-card">

            <!-- Image slider -->
            <div class="card-img-wrap" data-images='<%- JSON.stringify(home.url) %>'>
              <img class="slider card-img" src="<%= home.url[0] %>" alt="<%= home.houseName %>"/>

              <button onclick="prevImage(this)" class="slider-btn slider-btn-prev" aria-label="Previous image">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button onclick="nextImage(this)" class="slider-btn slider-btn-next" aria-label="Next image">
                <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
              </button>

              <span class="img-badge">Entire home</span>
              <div class="slider-dots"></div>
            </div>

            <!-- Content -->
            <div class="card-body">

              <div class="card-title-row">
                <h3 class="card-title"><%= home.houseName %></h3>
                <!-- <p><%= home.url[0] %></p> -->
                <span class="card-rating">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  <%= home.rating || "4.5" %>
                </span>
              </div>

              <p class="card-location">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <%= home.location || "Unknown location" %>
              </p>

              <p class="card-desc">
                <%= home.description || "Cozy and comfortable stay with great amenities nearby." %>
              </p>

              <div class="card-footer">
                <div class="card-price">
                  <span class="price-amount">$<%= home.price || "120" %></span>
                  <span class="price-unit"> / night</span>
                </div>

                <% if(role === 'guest') { %>
                  <a href="/homes/<%= home._id %>" class="btn-view">View</a>
                <% } %>
              </div>

            </div>

          </div>
        <% }) %>
      </div>

    <% } else { %>

      <div class="empty-state">
        <div class="empty-icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose-muted)" stroke-width="1.5">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <p class="empty-title">No homes available yet.</p>
        <a href="/host/add-home" class="btn-primary-sm">Add your first home</a>
      </div>

    <% } %>

  </section>

  <%- include('../partials/image-slider') %>

</body>

<style>
  /* ── Hero ── */
  .hero-section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(160deg, #fff5f6 0%, #faf9fb 55%, #f0f9ff 100%);
    padding: 7rem 1.5rem 5rem;
    text-align: center;
  }
  .hero-bg-mesh {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden;
  }
  .hero-bg-mesh::before {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(244,63,94,0.08) 0%, transparent 70%);
    top: -200px; left: 50%; transform: translateX(-50%);
  }
  .hero-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }
  .pill-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-rose);
    background: var(--color-rose-soft);
    border: 1px solid #fecdd3;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-pill);
    margin-bottom: 1.5rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .hero-title em {
    font-style: italic;
    color: var(--color-rose);
  }
  .hero-sub {
    font-size: 1.0625rem;
    color: var(--color-slate);
    max-width: 500px;
    margin: 0 auto 2.5rem;
    line-height: 1.65;
    font-weight: 300;
  }
  .hero-cta-row { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .hero-wave {
    position: absolute; bottom: -1px; left: 0; right: 0;
    height: 60px; pointer-events: none;
  }
  .hero-wave svg { width: 100%; height: 100%; display: block; }

  /* ── Listings section ── */
  .listings-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }
  .listings-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    margin-bottom: 0.2rem;
  }
  .section-sub { font-size: 0.875rem; color: var(--color-slate); }
  .results-badge {
    font-size: 0.8125rem;
    color: var(--color-slate);
    background: white;
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.85rem;
    border-radius: var(--radius-pill);
  }

  /* ── Card grid ── */
  .homes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }
  .home-card {
    background: white;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }
  .home-card:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-3px);
  }

  /* Image */
  .card-img-wrap {
    width: 100%;
    aspect-ratio: 3 / 2;   /* 1200:800 */
    overflow: hidden;
    border-radius: 16px 16px 0 0;
    position: relative;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .home-card:hover .card-img { transform: scale(1.03); }

  .img-badge {
    position: absolute;
    top: 12px; left: 12px;
    font-size: 0.72rem;
    font-weight: 600;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(6px);
    color: var(--color-ink);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    letter-spacing: 0.01em;
  }

  /* Card body */
  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.6rem;
  }
  .card-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.35;
    transition: color 0.15s ease;
  }
  .home-card:hover .card-title { color: var(--color-rose); }
  .card-rating {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #d97706;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .card-location {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8125rem;
    color: var(--color-slate);
  }
  .card-location svg { width: 14px; height: 14px; flex-shrink: 0; }
  .card-desc {
    font-size: 0.8125rem;
    color: var(--color-slate);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    margin-top: auto;
    padding-top: 0.875rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .card-price { display: flex; align-items: baseline; gap: 1px; }
  .price-amount { font-size: 1.125rem; font-weight: 700; color: var(--color-ink); }
  .price-unit { font-size: 0.8125rem; color: var(--color-slate); }

  /* Buttons */
  .btn-view {
    font-size: 0.8125rem;
    font-weight: 600;
    color: white;
    background: var(--color-rose);
    padding: 0.45rem 1.1rem;
    border-radius: var(--radius-pill);
    transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.1s ease;
  }
  .btn-view:hover {
    background: var(--color-rose-deep);
    box-shadow: 0 4px 14px rgba(244,63,94,0.3);
    transform: translateY(-1px);
  }
  .btn-primary-sm {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
    background: var(--color-rose);
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius-pill);
    transition: background 0.15s ease, box-shadow 0.15s ease;
  }
  .btn-primary-sm:hover {
    background: var(--color-rose-deep);
    box-shadow: 0 4px 14px rgba(244,63,94,0.3);
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 6rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .empty-icon {
    width: 72px; height: 72px;
    background: var(--color-rose-soft);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .empty-title { font-size: 1rem; color: var(--color-slate); }
</style>

</html>
