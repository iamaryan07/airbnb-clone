<%- include('../partials/head') %>

<body>

  <%- include('../partials/nav') %>

  <!-- Hero Header -->
  <section class="fav-hero">
    <div class="fav-hero-inner">
      <span class="pill-badge">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <circle cx="5" cy="5" r="4" fill="var(--color-rose)" opacity="0.25"/>
          <circle cx="5" cy="5" r="2" fill="var(--color-rose)"/>
        </svg>
        Your saved stays
      </span>
      <h1 class="fav-title">Favourite Homes</h1>
      <p class="fav-sub">Quickly access places you've saved for later.</p>
    </div>
  </section>

  <!-- Listings -->
  <section class="listings-section">

    <div class="listings-header">
      <div>
        <h2 class="section-title">Saved Homes</h2>
        <p class="section-sub">Your personal collection of stays</p>
      </div>
      <span class="results-badge"><%= favouriteHomes.length %> saved</span>
    </div>

    <% if (favouriteHomes.length > 0) { %>

      <div class="homes-grid">

        <% favouriteHomes.forEach(home => { %>

          <div class="home-card">

            <!-- Image slider -->
            <div class="card-img-wrap" data-images='<%- JSON.stringify(home.url) %>'>
              <img class="slider card-img" src="<%= home.url[0] %>" alt="<%= home.houseName %>"/>

              <button onclick="prevImage(this)" class="slider-btn slider-btn-prev" aria-label="Previous image">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button onclick="nextImage(this)" class="slider-btn slider-btn-next" aria-label="Next image">
                <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
              </button>

              <span class="img-badge">Entire home</span>
              <div class="slider-dots"></div>
            </div>

            <!-- Content -->
            <div class="card-body">

              <div class="card-title-row">
                <h3 class="card-title"><%= home.houseName %></h3>
                <span class="card-rating">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  <%= home.rating || "4.5" %>
                </span>
              </div>

              <p class="card-location">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <%= home.location || "Unknown location" %>
              </p>

              <p class="card-desc">
                <%= home.description || "Cozy and comfortable stay with great amenities nearby." %>
              </p>

              <div class="card-footer">
                <div class="card-price">
                  <span class="price-amount">$<%= home.price || "120" %></span>
                  <span class="price-unit"> / night</span>
                </div>
              </div>

              <!-- Actions -->
              <div class="card-actions">
                <a href="/homes/<%= home._id %>" class="btn-view">View</a>

                <form action="/favourites/remove/<%= home._id %>" method="POST" style="flex:1;">
                  <button type="submit" class="btn-remove">Remove</button>
                </form>
              </div>

            </div>

          </div>

        <% }) %>

      </div>

    <% } else { %>

      <div class="empty-state">
        <div class="empty-icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose-muted)" stroke-width="1.5">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <p class="empty-title">No favourites yet.</p>
        <p class="empty-sub">Save homes you love and find them here.</p>
        <a href="/homes" class="btn-primary-sm">Browse homes</a>
      </div>

    <% } %>

  </section>

  <%- include('../partials/image-slider') %>

</body>

<style>
  /* Hero */
  .fav-hero {
    background: linear-gradient(160deg, #fff5f6 0%, #faf9fb 55%, #f0f9ff 100%);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .fav-hero::before {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(244,63,94,0.07) 0%, transparent 70%);
    top: -180px; left: 50%; transform: translateX(-50%);
    pointer-events: none;
  }

  .fav-hero-inner {
    position: relative;
    max-width: 600px;
    margin: 0 auto;
  }

  .pill-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-rose);
    background: var(--color-rose-soft);
    border: 1px solid #fecdd3;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-pill);
    margin-bottom: 1.25rem;
  }

  .fav-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .fav-sub {
    font-size: 1rem;
    color: var(--color-slate);
    font-weight: 300;
    line-height: 1.65;
  }

  /* Listings section */
  .listings-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  .listings-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    margin-bottom: 0.2rem;
  }

  .section-sub { font-size: 0.875rem; color: var(--color-slate); }

  .results-badge {
    font-size: 0.8125rem;
    color: var(--color-slate);
    background: white;
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.85rem;
    border-radius: var(--radius-pill);
  }

  /* Grid */
  .homes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .home-card {
    background: white;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .home-card:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-3px);
  }

  /* Image */
  .card-img-wrap {
    width: 100%;
    aspect-ratio: 3 / 2;   /* 1200×800 */
    overflow: hidden;
    position: relative;
    border-radius: var(--radius-xl);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-card:hover .card-img { transform: scale(1.03); }

  .img-badge {
    position: absolute;
    top: 12px; left: 12px;
    font-size: 0.72rem;
    font-weight: 600;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(6px);
    color: var(--color-ink);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
  }

  /* Card body */
  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.6rem;
  }

  .card-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.35;
    transition: color 0.15s ease;
  }

  .home-card:hover .card-title { color: var(--color-rose); }

  .card-rating {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #d97706;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-location {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8125rem;
    color: var(--color-slate);
  }

  .card-location svg { width: 14px; height: 14px; flex-shrink: 0; }

  .card-desc {
    font-size: 0.8125rem;
    color: var(--color-slate);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 0.875rem;
    border-top: 1px solid var(--color-border);
  }

  .card-price { display: flex; align-items: baseline; gap: 1px; }
  .price-amount { font-size: 1.125rem; font-weight: 700; color: var(--color-ink); }
  .price-unit { font-size: 0.8125rem; color: var(--color-slate); }

  /* Actions */
  .card-actions {
    display: flex;
    gap: 0.625rem;
    margin-top: 0.5rem;
  }

  .btn-view {
    flex: 1;
    text-align: center;
    font-size: 0.8125rem;
    font-weight: 600;
    color: white;
    background: var(--color-rose);
    padding: 0.55rem 1rem;
    border-radius: var(--radius-pill);
    transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.1s ease;
  }

  .btn-view:hover {
    background: var(--color-rose-deep);
    box-shadow: 0 4px 14px rgba(244,63,94,0.3);
    transform: translateY(-1px);
  }

  .btn-remove {
    width: 100%;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #dc2626;
    background: #fef2f2;
    border: 1px solid #fecaca;
    padding: 0.55rem 1rem;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .btn-remove:hover {
    background: #fee2e2;
    border-color: #f87171;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 6rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .empty-icon {
    width: 72px; height: 72px;
    background: var(--color-rose-soft);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 0.5rem;
  }

  .empty-title { font-size: 1.0625rem; font-weight: 600; color: var(--color-ink); }
  .empty-sub { font-size: 0.875rem; color: var(--color-slate); }

  .btn-primary-sm {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
    background: var(--color-rose);
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius-pill);
    margin-top: 0.5rem;
    transition: background 0.15s ease, box-shadow 0.15s ease;
  }

  .btn-primary-sm:hover {
    background: var(--color-rose-deep);
    box-shadow: 0 4px 14px rgba(244,63,94,0.3);
  }

  /* Slider buttons */
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(4px);
    border: none;
    border-radius: 50%;
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.15s ease;
    z-index: 2;
  }

  .slider-btn:hover { background: white; }
  .slider-btn svg { width: 14px; height: 14px; stroke: var(--color-ink); stroke-width: 2.5; fill: none; }
  .slider-btn-prev { left: 10px; }
  .slider-btn-next { right: 10px; }
</style>

</html>
