<style>
  .fav-form { width: 100%; }

  .fav-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-rose);
    background: var(--color-rose-soft);
    border: 1.5px solid #fecdd3;
    border-radius: var(--radius-lg);
    padding: 0.7rem 1rem;
    cursor: pointer;
    transition:
      background   0.18s ease,
      border-color 0.18s ease,
      color        0.18s ease,
      transform    0.12s ease,
      box-shadow   0.18s ease;
    letter-spacing: 0.01em;
  }

  .fav-btn:hover {
    background: var(--color-rose);
    border-color: var(--color-rose);
    color: white;
    box-shadow: 0 4px 18px rgba(244,63,94,0.28);
    transform: translateY(-1px);
  }

  .fav-btn:active {
    transform: translateY(0) scale(0.98);
    box-shadow: none;
  }

  .fav-btn:hover .fav-heart {
    fill: white;
    stroke: white;
    animation: heartBeat 0.35s ease;
  }

  .fav-heart {
    fill: var(--color-rose-muted);
    stroke: var(--color-rose);
    stroke-width: 1.5;
    transition: fill 0.18s ease, stroke 0.18s ease;
    flex-shrink: 0;
  }

  @keyframes heartBeat {
    0%   { transform: scale(1); }
    35%  { transform: scale(1.3); }
    65%  { transform: scale(0.92); }
    100% { transform: scale(1); }
  }
</style>

<form action="/favourites" method="POST" class="fav-form">

  <input type="hidden" name="id" value="<%= home._id %>">

  <button type="submit" class="fav-btn">
    <!-- Heart SVG — inline, no CDN -->
    <svg
      class="fav-heart"
      width="16" height="16"
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
    Add to Favourites
  </button>

</form>
