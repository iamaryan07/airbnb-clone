<style>
  /* ── Image Slider Styles ─────────────────────────────────────────── */
  [data-images] {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: #f3eff2;
  }

  /* The actual image */
  [data-images] .slider {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.25s ease;
  }

  /* Shared arrow button */
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;

    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    cursor: pointer;

    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: var(--color-ink);
    box-shadow: 0 2px 10px rgba(26,17,23,0.18);

    display: flex;
    align-items: center;
    justify-content: center;

    opacity: 0;
    transition: opacity 0.2s ease, transform 0.15s ease, background 0.15s ease;
  }

  [data-images]:hover .slider-btn {
    opacity: 1;
  }

  .slider-btn:hover {
    background: rgba(255,255,255,1);
    box-shadow: 0 4px 18px rgba(26,17,23,0.22);
    transform: translateY(-50%) scale(1.08);
  }

  .slider-btn:active {
    transform: translateY(-50%) scale(0.96);
  }

  .slider-btn svg {
    width: 14px;
    height: 14px;
    stroke: var(--color-ink);
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
    pointer-events: none;
  }

  .slider-btn-prev { left:  10px; }
  .slider-btn-next { right: 10px; }

  /* Dot indicators */
  .slider-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 5px;
    z-index: 10;
    pointer-events: none;
  }

  .slider-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.55);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .slider-dot.active {
    background: white;
    transform: scale(1.25);
  }
</style>

<script>
  function getContainer(btn) {
    return btn.closest("[data-images]");
  }

  function getImages(container) {
    return JSON.parse(container.dataset.images);
  }

  function getImgTag(container) {
    return container.querySelector(".slider");
  }

  /* ── Added: dot sync helper (non-breaking) ── */
  function syncDots(container, index) {
    const dots = container.querySelectorAll('.slider-dot');
    dots.forEach(function(d, i) {
      d.classList.toggle('active', i === index);
    });
  }

  function nextImage(btn) {
    const container = getContainer(btn);
    const images    = getImages(container);
    const img       = getImgTag(container);

    let index = Number(container.dataset.index || 0);
    index = (index + 1) % images.length;

    container.dataset.index = index;
    img.src = "/uploads/" + images[index];
    syncDots(container, index);
  }

  function prevImage(btn) {
    const container = getContainer(btn);
    const images    = getImages(container);
    const img       = getImgTag(container);

    let index = Number(container.dataset.index || 0);
    index = (index - 1 + images.length) % images.length;

    container.dataset.index = index;
    img.src = "/uploads/" + images[index];
    syncDots(container, index);
  }

  /* ── Init dots on page load ── */
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-images]').forEach(function(container) {
      const images = JSON.parse(container.dataset.images || '[]');
      const dotsEl = container.querySelector('.slider-dots');
      if (!dotsEl || images.length <= 1) return;

      images.forEach(function(_, i) {
        const dot = document.createElement('span');
        dot.className = 'slider-dot' + (i === 0 ? ' active' : '');
        dotsEl.appendChild(dot);
      });
    });
  });
</script>
